# ============================================================
# Opera Concierge — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (Realtime voice + LLM tools) ---
OPENAI_API_KEY=

# --- Anthropic (OPTIONAL — fallback LLM) ---
ANTHROPIC_API_KEY=

# --- Auth ---
# Comma-separated list of operator emails allowed to sign into the dashboard.
# Empty/undefined = fail closed (no one can sign in).
ALLOWED_EMAILS=you@example.com

# --- App (OPTIONAL — auto-derived by Vercel from deployment URL if omitted) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WIDGET_CDN_URL=http://localhost:3000/widget.js
